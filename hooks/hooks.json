{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "obsidian-session-init",
            "type": "command",
            "command": "bash ${extensionPath}/scripts/session-init.sh",
            "timeout": 120000,
            "description": "Reports vault status and refreshes the RAG index when a Gemini session starts."
          }
        ]
      }
    ],
    "BeforeTool": [],
    "AfterTool": []
  }
}
